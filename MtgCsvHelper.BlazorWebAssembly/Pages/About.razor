@page "/about"

@inject HttpClient HttpClient
@using Markdig

<PageTitle>About — MtG CSV Helper</PageTitle>

<MudPaper Elevation="0" Class="pa-6">
	@if (_html is null)
	{
		<MudProgressLinear Indeterminate="true" />
	}
	else
	{
		<div class="cm-markdown">
			@((MarkupString)_html)
		</div>
	}
</MudPaper>

@code {
	string? _html;

	protected override async Task OnInitializedAsync()
	{
		var md = await HttpClient.GetStringAsync("README.md");
		_html = Markdown.ToHtml(md);
	}
}
