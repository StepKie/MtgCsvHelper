@page "/"
@inject IConfiguration Config
@inject ICardmarketResolver Resolver
@inject IReferenceCardCatalog Catalog
@inject IJSRuntime JS
@using Serilog
@using System.Text
@using CsvHelper
@implements IDisposable

<PageTitle>MtG CSV Helper</PageTitle>

<MudCard Elevation="2" Class="mb-6">
	<MudCardContent>
		<MudStack Spacing="4">
			<MudStack Spacing="2" AlignItems="AlignItems.Start">
				<InputFile id="fileUpload" OnChange="HandleFileChange" accept=".csv" style="display:none" />
				<MudButton HtmlTag="label" for="fileUpload" Variant="Variant.Filled" Color="Color.Primary"
				           StartIcon="@Icons.Material.Filled.CloudUpload" Size="Size.Large">
					Choose CSV file
				</MudButton>
				@if (_csvFile is not null)
				{
					<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
						<MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" />
						<MudTooltip Text="@_csvFile.Name" Placement="Placement.Top">
							<MudText Typo="Typo.body2" Style="max-width:360px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;">@_csvFile.Name</MudText>
						</MudTooltip>
						<MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatBytes(_csvFile.Size)</MudText>
					</MudStack>
				}
				else
				{
					<MudText Typo="Typo.caption" Class="mud-text-secondary">Up to @(MaxFileSize / 1024 / 1024) MB</MudText>
				}
			</MudStack>

			<MudGrid Spacing="3" Justify="Justify.Center">
				<MudItem xs="12" sm="5">
					<MudSelect T="string" Value="_selectedInputFormat" ValueChanged="OnInputFormatChanged" Label="Input format" Variant="Variant.Outlined" Dense="true" Disabled="@(_autoDetect && !_autoDetectFailed)">
						@foreach (var fmt in _supportedFormats)
						{
							<MudSelectItem Value="@fmt">@FormatDisplay.For(fmt)</MudSelectItem>
						}
					</MudSelect>
				</MudItem>
				<MudItem xs="12" sm="2" Style="display:flex;align-items:center;justify-content:center;">
					<MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Large" Class="mud-text-secondary" />
				</MudItem>
				<MudItem xs="12" sm="5">
					<MudSelect T="string" Value="_selectedOutputFormat" ValueChanged="OnOutputFormatChanged" Label="Output format" Variant="Variant.Outlined" Dense="true">
						@foreach (var fmt in _supportedFormats)
						{
							<MudSelectItem Value="@fmt">@FormatDisplay.For(fmt)</MudSelectItem>
						}
					</MudSelect>
				</MudItem>
			</MudGrid>
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
				<MudSwitch T="bool" Value="_autoDetect" ValueChanged="OnAutoDetectChanged" Color="Color.Primary" Size="Size.Small" />
				<MudText Typo="Typo.caption">Auto-detect</MudText>
				@if (_autoDetect && _autoDetectResult is not null)
				{
					<MudTooltip Text="Format detected from CSV headers">
						<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
					</MudTooltip>
				}
				else if (_autoDetect && _autoDetectFailed)
				{
					<MudTooltip Text="Couldn't detect format — pick manually">
						<MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
					</MudTooltip>
				}
			</MudStack>
		</MudStack>
	</MudCardContent>
	<MudCardActions Class="d-flex justify-content-center px-4 pb-4">
		<MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="Convert"
		           Disabled="@(_csvFile is null || _isConverting)"
		           StartIcon="@(_isConverting ? null : Icons.Material.Filled.PlayArrow)">
			@if (_isConverting)
			{
				<MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
				<text>Converting…</text>
			}
			else
			{
				<text>Convert</text>
			}
		</MudButton>
	</MudCardActions>
</MudCard>

@if (!string.IsNullOrEmpty(_headerError))
{
	<MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _headerError = null)">
		@_headerError
	</MudAlert>
}

@if (_result is { } r)
{
	var summary = r.Summary;
	<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap" Spacing="2">
		<div>
			<MudText Typo="Typo.h5">Imported @FormatDisplay.For(r.InputFormat) → @FormatDisplay.For(r.OutputFormat)</MudText>
			<MudText Typo="Typo.caption" Class="mud-text-secondary">@r.ImportedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
		</div>
		<MudSpacer />
		@if (r.OutputStream is not null)
		{
			<MudButton Variant="Variant.Filled" Color="Color.Success"
			           StartIcon="@Icons.Material.Filled.Download" OnClick="DownloadResult">
				Download CSV
			</MudButton>
		}
		@if (r.Issues.Any(i => i.Severity == IssueSeverity.Error))
		{
			<MudButton Variant="Variant.Outlined" Color="Color.Warning"
			           StartIcon="@Icons.Material.Filled.ReportProblem" OnClick="DownloadErrorCsv">
				Error report
			</MudButton>
		}
	</MudStack>

	<MudCard Elevation="1" Class="mb-4 cm-totals-strip">
		<MudCardContent Class="py-2">
			<MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap" Spacing="6">
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
					<MudIcon Icon="@Icons.Material.Filled.Style" Size="Size.Small" />
					<MudText Typo="Typo.body2"><strong>@summary.TotalCount</strong> cards</MudText>
				</MudStack>
				<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
					<MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
					<MudText Typo="Typo.body2"><strong>@summary.UniqueCount</strong> unique</MudText>
				</MudStack>
				@if (summary.FoilCount > 0)
				{
					<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
						<MudIcon Icon="@Icons.Material.Filled.Diamond" Size="Size.Small" Color="Color.Warning" />
						<MudText Typo="Typo.body2"><strong>@summary.FoilCount</strong> foil</MudText>
					</MudStack>
				}
				@if (summary.TotalValue is not null)
				{
					<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
						<MudIcon Icon="@Icons.Material.Filled.Sell" Size="Size.Small" />
						<MudText Typo="Typo.body2"><strong>@summary.TotalValue.Print()</strong></MudText>
					</MudStack>
				}
				@if (summary.MostExpensive is not null)
				{
					<MudText Typo="Typo.caption" Class="mud-text-secondary">
						Top: @summary.MostExpensive.Printing.Name (@summary.MostExpensive.PriceBought!.Print())
					</MudText>
				}
			</MudStack>
		</MudCardContent>
	</MudCard>

	@if (r.Issues.Count > 0)
	{
		var errorCount = r.Issues.Count(i => i.Severity == IssueSeverity.Error);
		var warningCount = r.Issues.Count(i => i.Severity == IssueSeverity.Warning);
		<MudExpansionPanels Class="mb-4" Elevation="1">
			<MudExpansionPanel Expanded="@(r.Issues.Count <= 20)">
				<TitleContent>
					<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
						<MudIcon Icon="@Icons.Material.Filled.Warning" Color="@(errorCount > 0 ? Color.Error : Color.Warning)" />
						<MudText>Import issues</MudText>
						@if (errorCount > 0)
						{
							<MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">@errorCount @(errorCount == 1 ? "row" : "rows") skipped</MudChip>
						}
						@if (warningCount > 0)
						{
							<MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">@warningCount @(warningCount == 1 ? "row" : "rows") imported with warnings</MudChip>
						}
					</MudStack>
				</TitleContent>
				<ChildContent>
					@{
						var grouped = r.Issues
							.GroupBy(i => (i.Severity, i.Reason))
							.OrderByDescending(g => g.Key.Severity == IssueSeverity.Error)
							.ThenByDescending(g => g.Count())
							.ToList();
					}
					<MudList T="object" Dense="true">
						@foreach (var g in grouped)
						{
							var (severity, reason) = g.Key;
							var rows = g.Select(i => i.RowNumber).OrderBy(rowNum => rowNum).ToList();
							var preview = string.Join(", ", rows.Take(8));
							if (rows.Count > 8) preview += $", … (+{rows.Count - 8} more)";
							<MudListItem T="object" Icon="@(severity == IssueSeverity.Error ? Icons.Material.Filled.Error : Icons.Material.Filled.Warning)"
							             IconColor="@(severity == IssueSeverity.Error ? Color.Error : Color.Warning)">
								<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
									<MudText Typo="Typo.body2"><strong>@reason</strong></MudText>
									<MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@g.Count() row@(g.Count() == 1 ? "" : "s")</MudChip>
								</MudStack>
								<MudText Typo="Typo.caption" Class="mud-text-secondary">@(rows.Count == 1 ? "row" : "rows"): @preview</MudText>
							</MudListItem>
						}
					</MudList>
				</ChildContent>
			</MudExpansionPanel>
		</MudExpansionPanels>
	}

	@if (r.Records.Count > 0)
	{
		<MudCard Elevation="1">
			<MudCardContent>
				<MudTable Items="r.Records" Filter="FilterRecord" Hover="true" Dense="true" Striped="true"
				          Breakpoint="Breakpoint.Sm" SortLabel="Sort by">
					<ToolBarContent>
						<MudText Typo="Typo.h6">Processed records</MudText>
						<MudChip T="string" Size="Size.Small" Class="ml-2">@r.Records.Count</MudChip>
						<MudSpacer />
						<MudTextField @bind-Value="_searchString" Placeholder="Search name or set" Adornment="Adornment.Start"
						              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Clearable="true"
						              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-0" />
					</ToolBarContent>
					<HeaderContent>
						<MudTh><MudTableSortLabel SortBy="@(new Func<PhysicalMtgCard, object>(c => c.Count))">Qty</MudTableSortLabel></MudTh>
						<MudTh><MudTableSortLabel InitialDirection="SortDirection.Ascending" SortBy="@(new Func<PhysicalMtgCard, object>(c => c.Printing.Name))">Name</MudTableSortLabel></MudTh>
						<MudTh><MudTableSortLabel SortBy="@(new Func<PhysicalMtgCard, object>(c => c.Printing.SetName))">Set</MudTableSortLabel></MudTh>
						<MudTh>Foil</MudTh>
						<MudTh><MudTableSortLabel SortBy="@(new Func<PhysicalMtgCard, object>(c => c.Condition))">Condition</MudTableSortLabel></MudTh>
						<MudTh><MudTableSortLabel SortBy="@(new Func<PhysicalMtgCard, object>(c => c.Language ?? ""))">Lang</MudTableSortLabel></MudTh>
						<MudTh><MudTableSortLabel SortBy="@(new Func<PhysicalMtgCard, object>(c => c.PriceBought?.Value ?? 0m))">Price</MudTableSortLabel></MudTh>
					</HeaderContent>
					<RowTemplate Context="card">
						@{
							var refCard = ResolveRef(card);
							var imageUrl = refCard is not null ? ScryfallImage.Url(refCard.Id) : null;
							var cardPageUrl = refCard is not null ? ScryfallImage.CardPageUrl(refCard.Set, refCard.CollectorNumber) : null;
							var setPageUrl = refCard is not null ? ScryfallImage.SetPageUrl(refCard.Set) : null;
						}
						<MudTd DataLabel="Qty">@card.Count</MudTd>
						<MudTd DataLabel="Name">
							@if (imageUrl is not null)
							{
								<MudTooltip Placement="Placement.Right" Arrow="false" Color="Color.Transparent"
								            Delay="250" Duration="50" RootClass="cardart-tooltip">
									<TooltipContent>
										<img src="@imageUrl" alt="@card.Printing.Name"
										     width="244" height="340"
										     style="display:block;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,0.4);"
										     loading="lazy" />
									</TooltipContent>
									<ChildContent>
										<a href="@cardPageUrl" target="_blank" rel="noopener" class="cm-card-link">@card.Printing.Name</a>
										@if (!string.IsNullOrEmpty(card.Printing.CollectorNumber))
										{
											<span class="mud-text-secondary ml-1">#@card.Printing.CollectorNumber</span>
										}
									</ChildContent>
								</MudTooltip>
							}
							else
							{
								<span>@card.Printing.Name</span>
								@if (!string.IsNullOrEmpty(card.Printing.CollectorNumber))
								{
									<span class="mud-text-secondary ml-1">#@card.Printing.CollectorNumber</span>
								}
							}
						</MudTd>
						<MudTd DataLabel="Set">
							@if (setPageUrl is not null)
							{
								<a href="@setPageUrl" target="_blank" rel="noopener" class="cm-card-link">@card.Printing.SetName</a>
							}
							else
							{
								<span>@card.Printing.SetName</span>
							}
						</MudTd>
						<MudTd DataLabel="Foil">
							@if (card.Foil == true)
							{
								<MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">F</MudChip>
							}
						</MudTd>
						<MudTd DataLabel="Condition">@(card.Condition == CardCondition.UNKNOWN ? "" : card.Condition.ToString())</MudTd>
						<MudTd DataLabel="Lang">@(card.Language ?? "")</MudTd>
						<MudTd DataLabel="Price">@(card.PriceBought?.Print() ?? "")</MudTd>
					</RowTemplate>
					<PagerContent>
						<MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }" />
					</PagerContent>
				</MudTable>
			</MudCardContent>
		</MudCard>
	}
}

@code {
	const int MaxFileSize = 5 * 1024 * 1024;
	static readonly IReadOnlyList<string> _supportedFormats = CardMapFactory.Supported;

	string _selectedInputFormat = _supportedFormats[0];
	string _selectedOutputFormat = _supportedFormats[1];

	IBrowserFile? _csvFile;
	ConversionResult? _result;
	string _searchString = "";
	string? _headerError;
	bool _isConverting;
	bool _autoDetect = true;
	string? _autoDetectResult;  // non-null = last detection produced a format
	bool _autoDetectFailed;     // true = last detection ran against a file and returned null
	FormatDetector? _detector;

	readonly CancellationTokenSource _cts = new();

	async Task HandleFileChange(InputFileChangeEventArgs e)
	{
		_csvFile = e.File;
		await TryAutoDetectAsync();
	}

	async Task OnAutoDetectChanged(bool value)
	{
		_autoDetect = value;
		_autoDetectResult = null;
		_autoDetectFailed = false;
		if (_autoDetect) await TryAutoDetectAsync();
	}

	async Task TryAutoDetectAsync()
	{
		_autoDetectResult = null;
		_autoDetectFailed = false;
		if (!_autoDetect || _csvFile is null) return;

		_detector ??= new FormatDetector([.. CardMapFactory.From(Config)]);
		try
		{
			// maxAllowedSize is a *whole-file* size cap, not a read window — must be at
			// least as large as anything we'd accept for conversion, or OpenReadStream
			// throws and detection silently fails for big files.
			await using var stream = _csvFile.OpenReadStream(maxAllowedSize: MaxFileSize);
			var detected = await _detector.DetectAsync(stream);
			if (detected is not null)
			{
				_autoDetectResult = detected;
				OnInputFormatChanged(detected);
			}
			else
			{
				_autoDetectFailed = true;
			}
		}
		catch (Exception ex)
		{
			Log.Warning(ex, "Auto-detect failed");
			_autoDetectFailed = true;
		}
	}

	// Keep input ≠ output. When the user picks a value that matches the other select, snap
	// the other one to the first format in the list that isn't the new value.
	void OnInputFormatChanged(string value)
	{
		_selectedInputFormat = value;
		if (_selectedOutputFormat == value)
			_selectedOutputFormat = _supportedFormats.First(f => f != value);
		// A manual pick clears any prior auto-detect failure so the warning chip goes away.
		_autoDetectFailed = false;
	}

	void OnOutputFormatChanged(string value)
	{
		_selectedOutputFormat = value;
		if (_selectedInputFormat == value)
			_selectedInputFormat = _supportedFormats.First(f => f != value);
	}

	// Imported PhysicalMtgCard objects don't carry the Scryfall Id (the CSV parse only fills
	// Set/CollectorNumber/Name). We look up the reference printing here to source the image
	// URL and the canonical Scryfall page link. Returns null for stub rows that don't match
	// a real printing (e.g. unresolved Cardmarket imports).
	ReferenceCard? ResolveRef(PhysicalMtgCard card)
	{
		if (string.IsNullOrEmpty(card.Printing.Set) || string.IsNullOrEmpty(card.Printing.CollectorNumber))
			return null;
		return Catalog.FindBySetAndCollectorNumber(card.Printing.Set.ToLowerInvariant(), card.Printing.CollectorNumber);
	}

	bool FilterRecord(PhysicalMtgCard card)
	{
		if (string.IsNullOrWhiteSpace(_searchString)) return true;
		var s = _searchString.Trim();
		return card.Printing.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
		    || card.Printing.SetName.Contains(s, StringComparison.OrdinalIgnoreCase)
		    || card.Printing.Set.Contains(s, StringComparison.OrdinalIgnoreCase);
	}

	void Reset()
	{
		_result?.Dispose();
		_result = null;
		_headerError = null;
		_searchString = "";
	}

	static string FormatBytes(long bytes) => bytes switch
	{
		< 1024 => $"{bytes} B",
		< 1024 * 1024 => $"{bytes / 1024.0:0.#} KB",
		_ => $"{bytes / 1024.0 / 1024.0:0.#} MB",
	};

	async Task Convert()
	{
		try
		{
			_isConverting = true;
			Reset();
			StateHasChanged();
			await Task.Delay(1);

			Stream csvStream = new MemoryStream();
			await _csvFile!.OpenReadStream(maxAllowedSize: MaxFileSize).CopyToAsync(csvStream);
			csvStream.Position = 0;

			var reader = new MtgCardCsvHandler(Catalog, Resolver, Config, _selectedInputFormat);
			var writer = new MtgCardCsvHandler(Catalog, Resolver, Config, _selectedOutputFormat);

			var parsed = await reader.ParseCollectionCsvAsync(csvStream, _cts.Token);
			var records = parsed.Collection.Cards;
			var summary = CollectionSummary.From(records);

			MemoryStream? outputStream = null;
			string? outputFileName = null;
			if (records.Count > 0)
			{
				outputFileName = $"{_selectedInputFormat}-to-{_selectedOutputFormat}_{DateTime.Now:yyyy-MM-dd_HH-mm-ss}.csv";
				outputStream = new MemoryStream();
				writer.WriteCollectionCsv(records, outputStream);
			}

			_result = new ConversionResult
			{
				InputFormat = _selectedInputFormat,
				OutputFormat = _selectedOutputFormat,
				ImportedAt = DateTime.Now,
				Records = records,
				Issues = parsed.Issues,
				Summary = summary,
				OutputStream = outputStream,
				OutputFileName = outputFileName,
			};
		}
		catch (HeaderValidationException hex)
		{
			var missing = hex.InvalidHeaders.SelectMany(h => h.Names).Distinct().ToList();
			_headerError = $"This doesn't look like a valid {FormatDisplay.For(_selectedInputFormat)} CSV — missing required column(s): {string.Join(", ", missing)}. Did you select the correct input format?";
		}
		catch (OperationCanceledException)
		{
			return;
		}
		catch (Exception ex)
		{
			_headerError = $"Unexpected error converting file: {ex.Message}";
		}
		finally
		{
			_isConverting = false;
			StateHasChanged();
		}
	}

	async Task DownloadResult()
	{
		if (_result is not { OutputStream: { } stream, OutputFileName: { Length: > 0 } name })
		{
			Log.Warning("No result available, this should not happen");
			return;
		}

		stream.Position = 0;
		using var streamRef = new DotNetStreamReference(stream, leaveOpen: true);
		await JS.InvokeVoidAsync("downloadFileFromStream", name, streamRef);
	}

	async Task DownloadErrorCsv()
	{
		if (_result is null) return;
		var errors = _result.Issues.Where(i => i.Severity == IssueSeverity.Error).ToList();
		if (errors.Count == 0) return;

		var sb = new StringBuilder();
		sb.AppendLine("RowNumber,RawContent,Reason");
		foreach (var e in errors)
		{
			sb.AppendLine($"{e.RowNumber},{Csv(e.RawContent)},{Csv(e.Reason)}");
		}

		var bytes = Encoding.UTF8.GetBytes(sb.ToString());
		using var stream = new MemoryStream(bytes);
		using var streamRef = new DotNetStreamReference(stream, leaveOpen: false);
		await JS.InvokeVoidAsync("downloadFileFromStream", $"{_result.InputFormat}-import-errors-{DateTime.Now:yyyy-MM-dd_HH-mm-ss}.csv", streamRef);

		static string Csv(string? value) => value is null ? "" : $"\"{value.Replace("\"", "\"\"")}\"";
	}

	public void Dispose()
	{
		_cts.Cancel();
		_cts.Dispose();
		_result?.Dispose();
	}
}
