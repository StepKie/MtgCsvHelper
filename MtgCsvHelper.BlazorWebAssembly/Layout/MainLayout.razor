@inherits LayoutComponentBase
@using System.Reflection

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
	<MudAppBar Elevation="1" Dense="true">
		<MudLink Href="" Underline="Underline.None" Color="Color.Inherit">
			<MudText Typo="Typo.h6">MtG CsvHelper</MudText>
		</MudLink>
		<MudSpacer />
		<MudButton Href="about" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Info">About</MudButton>
		<MudText Typo="Typo.caption" Class="d-none d-sm-flex mx-3">v@_version · @_commit</MudText>
		<MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
			<MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
			               Color="Color.Inherit" OnClick="ToggleTheme" />
		</MudTooltip>
		<MudTooltip Text="Report a bug">
			<MudIconButton Icon="@Icons.Material.Filled.BugReport" Color="Color.Inherit"
			               Href="https://github.com/StepKie/MtgCsvHelper/issues/new/choose" Target="_blank" />
		</MudTooltip>
		<MudTooltip Text="Project on GitHub">
			<MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"
			               Href="https://github.com/StepKie/MtgCsvHelper/" Target="_blank" />
		</MudTooltip>
	</MudAppBar>
	<MudMainContent>
		<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
			@Body
		</MudContainer>
	</MudMainContent>
</MudLayout>

@code {
	static readonly string versionFull = Assembly.GetExecutingAssembly().GetCustomAttribute<AssemblyInformationalVersionAttribute>()!.InformationalVersion;
	readonly string _version = versionFull.Split("+")[0];
	readonly string _commit = versionFull.Split("+")[1].Remove(7);

	MudThemeProvider _themeProvider = null!;
	bool _isDarkMode = true;

	readonly MudTheme _theme = new()
	{
		PaletteLight = new PaletteLight
		{
			Primary = "#7c4dff",
			Secondary = "#ff5252",
		},
		PaletteDark = new PaletteDark
		{
			Primary = "#b388ff",
			Secondary = "#ff5252",
			Background = "#121212",
			Surface = "#1e1e1e",
			AppbarBackground = "#1a1a1a",
			DrawerBackground = "#1a1a1a",
		},
		LayoutProperties = new LayoutProperties
		{
			DefaultBorderRadius = "8px",
		},
	};

	void ToggleTheme() => _isDarkMode = !_isDarkMode;
}
